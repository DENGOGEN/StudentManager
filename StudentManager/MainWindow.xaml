<Window x:Class="StudentManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StudentManager"
        mc:Ignorable="d"
        Title="Менеджер Личных Дел" Height="500" Width="400"
        Background="#F5F5F7" WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <local:MainViewModel />
    </Window.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,15">
            <Button Content="📋 Список студентов" 
                    Command="{Binding ShowFullStudentListCommand}"
                    DockPanel.Dock="Right"
                    Padding="10,5" Height="32" FontSize="12" FontWeight="Medium"
                    Background="#0071E3" Foreground="White" BorderThickness="0" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>

            <TextBlock Text="Списки групп" FontSize="20" FontWeight="SemiBold" Foreground="#1D1D1F" VerticalAlignment="Center"/>
        </DockPanel>

        <TreeView Grid.Row="1" ItemsSource="{Binding DisplayedGroups}" Background="White" BorderBrush="#E5E5EA" BorderThickness="1">
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding Students}">
                    <DockPanel Margin="2" MinWidth="300">
                        <Button Content="+" 
                                Command="{Binding DataContext.AddStudentCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                DockPanel.Dock="Right"
                                Width="26" Height="26" FontSize="14" FontWeight="Bold"
                                Background="#0071E3" Foreground="White" BorderThickness="0" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="13"/>
                                </Style>
                            </Button.Resources>
                        </Button>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="📁 " Foreground="#FFCC00" FontSize="16"/>
                            <TextBlock Text="{Binding GroupName}" FontWeight="Bold" Foreground="#1D1D1F" FontSize="14"/>
                        </StackPanel>
                    </DockPanel>

                    <HierarchicalDataTemplate.ItemTemplate>
                        <DataTemplate>
                            <DockPanel Margin="5,2,2,2" MinWidth="260">
                                <Button Content="❌" 
                                        Command="{Binding DataContext.DeleteStudentCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        DockPanel.Dock="Right"
                                        Width="18" Height="18" FontSize="8"
                                        Background="#FFE5E5" Foreground="Red" BorderThickness="0" Cursor="Hand">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="9"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>

                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="👤 " Foreground="#8E8E93"/>
                                    <TextBlock Text="{Binding StudentName}" Foreground="#3A3A3C" FontSize="13"/>
                                </StackPanel>
                            </DockPanel>
                        </DataTemplate>
                    </HierarchicalDataTemplate.ItemTemplate>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </Grid>
</Window>